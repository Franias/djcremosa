!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Audio source files — currently committed to the repo (7 files, ~194MB)
# so the static GitHub Pages artifact always ships them. The deploy
# workflow's "Sync audio (from backup)" step is left in place but is a
# no-op when AUDIO_SRC is unset (the common case) — `scripts/sync-audio.sh`
# will warn and skip rather than overwrite the committed files.
#
# Future plan (option C): move the MP3s out of git by uploading them as
# GitHub Release assets on `Franias/djcremosa` and having the workflow
# download them with `gh release download` before `next build`. That
# keeps the source repo small without depending on a second private repo.
#
# Until that migration lands, the files stay in git; clear them from the
# index with `git rm --cached public/audio/*.mp3` only after the release
# pipeline is wired up.

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in to committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
